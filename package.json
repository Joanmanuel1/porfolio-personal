    "@unhead/vue": "^1.11.20",
    "@vueuse/motion": "^3.0.3",
    "aos": "^2.3.4",
    "lucide-vue-next": "^0.555.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.22",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.4.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
